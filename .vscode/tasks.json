{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build GUI (Debug)",
            "type": "shell",
            "command": "cmake --build build --config Debug --target augmentor_gui",
            "options": {
                "cwd": "${workspaceFolder}",
                "env": {
                    "TEMP": "${workspaceFolder}\\temp",
                    "TMP": "${workspaceFolder}\\temp"
                }
            },
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "Build GUI (Release)",
