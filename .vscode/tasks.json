{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build GUI (Release)",
            "type": "shell",
            "command": "cmake --build build --config Release --target augmentor_gui",
            "options": {
                "cwd": "${workspaceFolder}/cpp"
            },
            "group": "build",
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "Build CLI (Release)",
            "type": "shell",
            "command": "cmake --build build --config Release --target extract_moves",
            "options": {
                "cwd": "${workspaceFolder}/cpp"
            },
            "group": "build",
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "Build Tests (Release)",
            "type": "shell",
            "command": "cmake --build build --config Release --target test_extract_moves",
            "options": {
                "cwd": "${workspaceFolder}/cpp"
            },
            "group": "build",
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            },
            "problemMatcher": "$msCompile"
        }
    ]
}
